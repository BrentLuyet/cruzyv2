# Cruzy+ Portal — environment variables
# Copy this file to .env.local and fill in the real values. Do NOT commit .env.local.

# --- Salesforce ---
# Auth is the self-healing OAuth client-credentials flow (see SALESFORCE_AUTH.md).
# Production: set SF_CLIENT_ID + SF_CLIENT_SECRET + SF_INSTANCE_URL.
# Local-dev alternative: SF_ACCESS_TOKEN + SF_INSTANCE_URL (static CLI token).
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_INSTANCE_URL=
SF_ACCESS_TOKEN=

# --- Email (nodemailer, used for password-reset links) ---
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Authorize.net (payments) ---
AUTHNET_API_LOGIN_ID=
AUTHNET_TRANSACTION_KEY=
NEXT_PUBLIC_AUTHNET_API_LOGIN_ID=
NEXT_PUBLIC_AUTHNET_CLIENT_KEY=
NEXT_PUBLIC_AUTHNET_ENV=sandbox

# --- Auth & app ---
JWT_SECRET=
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_MEMBERSHIP_PRICE=
